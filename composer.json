{
  "name": "sharadkashyap/php-api-response-toolkit",
  "description": "A lightweight, framework-independent PHP toolkit for consistent JSON API responses and error handling.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Sharad Kashyap"
    }
  ],
  "homepage": "https://github.com/sharadkashyapdev/php-api-response-toolkit",
  "keywords": [
    "php",
    "api",
    "json",
    "response",
    "rest"
  ],
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "SharadKashyap\\ApiResponse\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SharadKashyap\\ApiResponse\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.95"
  },
  "scripts": {
  "test": "vendor/bin/phpunit",
  "analyse": "vendor/bin/phpstan analyse",
  "format": "vendor/bin/php-cs-fixer fix"
}
}